# Copy this file to `.env.local` and fill in your Supabase project values.
# Supabase Dashboard → Project Settings → API
# The anon key is safe to expose (RLS protects your data). Never use service_role here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Email (optional) — send grade emails via a Gmail account (SMTP) ---------
# Server-side only (no NEXT_PUBLIC_). If omitted, the app still works and just
# skips sending email (in-system notifications still show the component scores).
# No domain needed — good for delivering to real Gmail inboxes (~500/day).
# Steps: on a Google account with 2-Step Verification, create an App Password
# (Google Account → Security → App passwords) and paste the 16 chars below.
GMAIL_USER=vnuis.risk.alert@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Display name shown as the sender (the address is always GMAIL_USER).
NOTIFY_FROM_NAME=Hệ thống Cảnh báo Rủi ro Học tập — VNU-IS
