# Copy this file to `.env.local` and fill in your Supabase project values.
# Supabase Dashboard → Project Settings → API
# The anon key is safe to expose (RLS protects your data). Never use service_role here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Email (optional) — send grade emails via Resend (https://resend.com) ---
# Server-side only (no NEXT_PUBLIC_). If omitted, the app still works and just
# skips sending email (in-system notifications still show the component scores).
RESEND_API_KEY=
# Verified sender. For quick testing you can use the shared address below, which
# only delivers to your own Resend account email. Use your verified domain to
# email real students, e.g. "Academic Alerts <alerts@yourschool.edu.vn>".
NOTIFY_FROM=Academic Risk Alert <onboarding@resend.dev>
